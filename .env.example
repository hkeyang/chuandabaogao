# AISea production environment

# Frontend
VITE_PUBLIC_BASE_URL=https://hair.aisea.space

# Cloudflare Worker secrets. Set with `wrangler secret put ...`; never commit real values.
ADMIN_PASSWORD_SECRET=replace-with-strong-admin-password
OPENAI_API_KEY=replace-with-openai-compatible-key

# Worker vars are also documented in wrangler.toml.
PUBLIC_BASE_URL=https://hair.aisea.space
R2_PUBLIC_BASE_URL=https://img.hair.aisea.space
OPENAI_IMAGE_ENDPOINT=https://img.hair.aisea.space/v1/images/generations
OPENAI_IMAGE_MODEL=gpt-image-2
COUPON_VALID_DAYS=30

# R2/D1 binding names are configured in wrangler.toml:
# DB -> Cloudflare D1
# R2 -> Cloudflare R2 bucket
